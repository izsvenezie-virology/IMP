profiles {
    docker {
        outputDir           = "/pipeline_output"
        conda.enabled       = true
        conda.useMicromamba = true
        process {
            withLabel: multiThread {
                cpus = 6
            }
            withName: '!FastQC' {
                memory = '2 GB'
            }
            conda = "/env"
        }
        params {
            raw_reads_folder    = "/pipeline_input/raw_reads"
            samples_metadata    = "/pipeline_input/samples_metadata.tsv"
            references_database = "/pipeline_resources/references_database.fasta"
        }
    }
}
