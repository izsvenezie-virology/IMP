conda.enabled = true
report.enabled = true
trace.enabled = true
trace.raw = true

profiles{
    local{
        process{
            withLabel: multiThread{
                cpus = 2
            }
            conda = "${baseDir}/../../envs/aiv"
        }
    }
    bimaster{
        process{
            withLabel: multiThread{
                cpus = 10
            }
            errorStrategy = 'finish'
            conda = "/pbs/temp/edoardo/envs/aiv_pipeline/"
            clusterOptions = '-W sandbox=private -W umask=003'
        }
        executor.name = 'pbspro'
    }
}
