conda.enabled = true
report.enabled = true
trace.enabled = true
trace.raw = true

profiles{
    local{
        process{
            withLabel: multiThread{
                cpus = 2
            }
            conda = "${baseDir}/../../envs/aiv"
        }
    }
    bimaster{
        process{
            withLabel: multiThread{
                cpus = 10
            }
            errorStrategy = 'finish'
            conda = "/pbs/temp/edoardo/envs/aiv_pipeline/"
            clusterOptions = '-W sandbox=private -W umask=003'
        }
        executor.name = 'pbspro'
        
        params.null_file = "${projectDir}/resources/null.file"
        params.adapters = '/pbs/data/biv/bioinfo/data/adapters/adapters_nextera_trimmer.fa'
        params.references_database = '/pbs/temp/edoardo/pipelines/aiv_reference_db/gisaid_epiflu_all_unique_names.fa'
    }
}
