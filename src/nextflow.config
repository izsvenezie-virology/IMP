outputDir = '.'
workflow.output.mode = 'copy'

params.null_file = "${projectDir}/resources/null.file"
params.adapters = "${projectDir}/resources/adapters_nextera_trimmer.fa"

profiles {
    local {
        report.enabled = true
        conda.enabled = true
        conda.useMicromamba = true
        process {
            withLabel: multiThread {
                cpus = 6
                maxForks = 1
            }
            withName: '!FastQC' {
                memory = '2 GB'
            }
            conda = "/home/giussani.e/.micromamba/envs/imp"
        }
    }
    bivfe {
        report.enabled = true
        conda.enabled = true
        process {
            withLabel: multiThread {
                cpus = 10
            }
            errorStrategy = 'finish'
            conda = '/conda_envs/biv/imp'
            clusterOptions = '-W sandbox=private -W umask=002'
        }
        executor.name = 'pbspro'
        executor.jobName = { "${task.tag}_${task.process}" }
    }
    bivfe_develop {
        report.enabled = true
        conda.enabled = true
        process {
            withLabel: multiThread {
                cpus = 10
            }
            errorStrategy = 'finish'
            conda = '/pbs/scratch/biv/edoardo/envs/imp_develop'
            clusterOptions = '-W sandbox=private -W umask=002'
        }
        executor.name = 'pbspro'
        executor.jobName = { "${task.tag}_${task.process}" }
    }
}
